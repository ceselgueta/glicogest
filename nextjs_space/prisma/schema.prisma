generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/controle_diabetes_gestacional/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  password      String
  plan          String    @default("free")
  planExpiresAt DateTime? @map("plan_expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  readings        GestationalGlucoseReading[]
  patientSettings PatientSettings[]

  @@map("users")
}

enum ReadingType {
  JEJUM
  POS_CAFE_2H
  POS_ALMOCO_2H
  POS_JANTA_2H
}

model GestationalGlucoseReading {
  id          String      @id @default(uuid())
  userId      String?     @map("user_id")
  readingDate DateTime    @map("reading_date") @db.Date
  readingType ReadingType @map("reading_type")
  valueMgDl   Int         @map("value_mg_dl")
  readingTime  String?     @map("reading_time")
  notes        String?
  symptoms     String?     @map("symptoms")
  observations String?     @map("observations")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])

  @@unique([userId, readingDate, readingType])
  @@map("gestational_glucose_readings")
}

model PatientSettings {
  id               String   @id @default(uuid())
  userId           String?  @map("user_id")
  patientName      String   @map("patient_name")
  birthDate        DateTime? @map("birth_date") @db.Date
  pregnancyWeeks   Int?     @map("pregnancy_weeks")
  estimatedDueDate DateTime? @map("estimated_due_date") @db.Date
  doctorName       String?  @map("doctor_name")
  fastingTarget    Int      @default(95) @map("fasting_target")
  postMealTarget   Int      @default(120) @map("post_meal_target")
  postMealProtocol String   @default("2h") @map("post_meal_protocol")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("patient_settings")
}
