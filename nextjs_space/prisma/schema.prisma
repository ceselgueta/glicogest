generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  plan          String    @default("free")
  planExpiresAt DateTime? @map("plan_expires_at")
  planStartedAt DateTime? @map("plan_started_at")
  hasUsedTrial  Boolean   @default(false) @map("has_used_trial")
  pdfReportsGenerated Int @default(0) @map("pdf_reports_generated")
  paymentStatus String   @default("not_required") @map("payment_status")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts        Account[]
  readings        GestationalGlucoseReading[]
  patientSettings PatientSettings[]
  payments        Payment[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

enum ReadingType {
  JEJUM
  POS_CAFE_2H
  POS_ALMOCO_2H
  POS_JANTA_2H
}

model GestationalGlucoseReading {
  id          String      @id @default(uuid())
  userId      String?     @map("user_id")
  readingDate DateTime    @map("reading_date") @db.Date
  readingType ReadingType @map("reading_type")
  valueMgDl   Int         @map("value_mg_dl")
  readingTime  String?     @map("reading_time")
  notes        String?
  symptoms     String?     @map("symptoms")
  observations String?     @map("observations")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])

  @@unique([userId, readingDate, readingType])
  @@map("gestational_glucose_readings")
}

model Payment {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  planId          String   @map("plan_id")
  amount          Float
  status          String   @default("pending") // pending, approved, rejected, refunded
  mpPreferenceId  String?  @map("mp_preference_id")
  mpPaymentId     String?  @map("mp_payment_id")
  mpStatus        String?  @map("mp_status")
  mpStatusDetail  String?  @map("mp_status_detail")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model PatientSettings {
  id               String   @id @default(uuid())
  userId           String?  @map("user_id")
  patientName      String   @map("patient_name")
  birthDate        DateTime? @map("birth_date") @db.Date
  pregnancyWeeks   Int?     @map("pregnancy_weeks")
  estimatedDueDate DateTime? @map("estimated_due_date") @db.Date
  doctorName       String?  @map("doctor_name")
  fastingTarget    Int      @default(95) @map("fasting_target")
  postMealTarget   Int      @default(120) @map("post_meal_target")
  postMealProtocol String   @default("2h") @map("post_meal_protocol")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("patient_settings")
}
